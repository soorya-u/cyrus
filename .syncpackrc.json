{
  "$schema": "./node_modules/syncpack/schema.json",
  "versionGroups": [
    {
      "label": "Ignore package.json version fields on private workspace packages",
      "dependencyTypes": ["local"],
      "isIgnored": true
    },
    {
      "label": "Local workspace packages must use workspace:*",
      "dependencies": ["$LOCAL"],
      "dependencyTypes": ["prod", "dev"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "Auth deps must use catalog:auth",
      "dependencies": [
        "@better-auth/expo",
        "@soorya-u/better-auth-desktop",
        "@soorya-u/better-auth-ws-ticket",
        "better-auth"
      ],
      "dependencyTypes": ["prod", "dev"],
      "policy": "catalog"
    },
    {
      "label": "Database deps must use catalog:database",
      "dependencies": ["drizzle-kit", "drizzle-orm"],
      "dependencyTypes": ["prod", "dev"],
      "policy": "catalog"
    },
    {
      "label": "React deps must use catalog:react",
      "dependencies": [
        "@types/react",
        "@types/react-dom",
        "react",
        "react-dom"
      ],
      "dependencyTypes": ["prod", "dev"],
      "policy": "catalog"
    },
    {
      "label": "RPC deps must use catalog:rpc",
      "dependencies": ["@orpc/server", "@tanstack/react-query", "zod"],
      "dependencyTypes": ["prod", "dev"],
      "policy": "catalog"
    },
    {
      "label": "Testing deps must use catalog:testing",
      "dependencies": [
        "@vitest/coverage-istanbul",
        "@vitest/ui",
        "jsdom",
        "vitest"
      ],
      "dependencyTypes": ["prod", "dev"],
      "policy": "catalog"
    },
    {
      "label": "Env deps must use catalog:env",
      "dependencies": ["@dotenvx/dotenvx", "@t3-oss/env-core"],
      "dependencyTypes": ["prod", "dev"],
      "policy": "catalog"
    },
    {
      "label": "Observability deps must use catalog:observability",
      "dependencies": ["evlog"],
      "dependencyTypes": ["prod", "dev"],
      "policy": "catalog"
    },
    {
      "label": "Core deps must use catalog:core",
      "dependencies": ["@types/bun", "better-result", "typescript"],
      "dependencyTypes": ["prod", "dev"],
      "policy": "catalog"
    }
  ]
}
