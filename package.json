{
  "name": "cyrus",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@dotenvx/dotenvx": "^1.71.3",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.28",
      "@sinclair/typebox": "^0.34.0",
      "better-auth": "1.6.11",
      "evlog": "^2.18.1",
      "next-themes": "^0.4.6",
      "@tanstack/react-query": "^5.90.12",
      "@tanstack/react-form": "^1.28.0",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "@types/react-dom": "^19.2.3",
      "@better-auth/expo": "1.6.11",
      "drizzle-orm": "^0.45.1",
      "@types/pg": "^8.16.0",
      "@base-ui/react": "^1.4.1",
      "lucide-react": "^1.8.0",
      "nanostores": "^1.3.0",
      "better-result": "^2.9.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:mobile": "turbo -F @cyrus/mobile dev",
    "dev:web": "turbo -F @cyrus/web dev",
    "dev:desktop": "turbo -F @cyrus/desktop dev:hmr",
    "build:desktop": "turbo -F @cyrus/desktop build:stable",
    "build:desktop:canary": "turbo -F @cyrus/desktop build:canary",
    "build:vercel": "bun scripts/ci/vercel.ts",
    "dev:server": "turbo -F @cyrus/server dev",
    "dev:cli": "turbo -F @cyrus/cli dev",
    "dev:db": "docker compose up",
    "db:push": "bun env:load -- turbo -F @cyrus/db db:push",
    "db:studio": "bun env:load -- turbo -F @cyrus/db db:studio",
    "db:generate": "bun env:load -- turbo -F @cyrus/db db:generate",
    "db:migrate": "bun env:load -- turbo -F @cyrus/db db:migrate",
    "auth:generate": "bun env:load -- turbo -F @cyrus/auth auth:generate",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "env:load": "bun x dotenvx run -f apps/server/.env --"
  },
  "dependencies": {
    "@cyrus/env": "workspace:*",
    "@dotenvx/dotenvx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@cyrus/config": "workspace:*",
    "@noble/ciphers": "^1.3.0",
    "@types/bun": "catalog:",
    "@types/three": "^0.184.1",
    "lefthook": "latest",
    "turbo": "^2.9.18",
    "typescript": "catalog:",
    "ultracite": "7.8.1"
  },
  "overrides": {
    "@babel/generator": "7.29.7",
    "@babel/parser": "7.29.7",
    "@babel/types": "7.29.7",
    "@babel/template": "7.29.7",
    "@babel/traverse": "7.29.7",
    "@babel/helper-validator-identifier": "7.29.7"
  },
  "packageManager": "bun@1.3.14"
}
