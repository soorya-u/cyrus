{
  "$schema": "https://v2-10-4.turborepo.dev/schema.json",
  "ui": "stream",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "WEB_APP_URL",
    "CORS_ORIGIN",
    "CLI_PUBLIC_SERVER_URL",
    "NODE_ENV",
    "CYRUS_NIGHTLY_WEBRTC"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check:types": {
      "dependsOn": ["^check:types"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:e2e": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["dev:db"],
      "cache": false,
      "persistent": true
    },
    "dev:hmr": {
      "cache": false,
      "persistent": true
    },
    "dev:db": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:start": {
      "cache": false,
      "persistent": true
    },
    "db:stop": {
      "cache": false
    },
    "db:watch": {
      "cache": false,
      "persistent": true
    },
    "db:down": {
      "cache": false
    },
    "auth:generate": {
      "cache": false
    }
  }
}
