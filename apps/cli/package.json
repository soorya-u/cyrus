{
  "name": "@cyrus/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "cyrusd": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "check:types": "tsc --noEmit",
    "test:unit": "bun test",
    "build": "bun build src/cli.ts --compile --env 'CLI_PUBLIC_*' --outfile dist/cyrusd"
  },
  "dependencies": {
    "@acp-kit/core": "^0.10.2",
    "@agentclientprotocol/sdk": "^1.1.0",
    "@commander-js/extra-typings": "^15.0.0",
    "@cyrus/connections": "workspace:*",
    "@cyrus/database": "workspace:*",
    "@cyrus/schemas": "workspace:*",
    "@cyrus/utils": "workspace:*",
    "@tursodatabase/database": "^0.6.1",
    "@orpc/server": "catalog:",
    "@t3-oss/env-core": "catalog:",
    "better-auth": "catalog:",
    "better-result": "catalog:",
    "commander": "^15.0.0",
    "diff": "^7.0.0",
    "evlog": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cyrus/typescript": "workspace:*",
    "@types/bun": "catalog:",
    "@types/diff": "^7.0.0",
    "typescript": "catalog:"
  }
}
