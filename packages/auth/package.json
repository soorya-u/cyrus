{
  "name": "@cyrus/auth",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./client/web": {
      "default": "./src/client/web.ts"
    },
    "./client/mobile": {
      "default": "./src/client/mobile.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "generate": "bun x @better-auth/cli generate -y --config src/index.ts --output ../db/src/schema/auth.ts"
  },
  "dependencies": {
    "@better-auth/expo": "catalog:",
    "@cyrus/db": "workspace:*",
    "@cyrus/env": "workspace:*",
    "better-auth": "catalog:",
    "nanostores": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cyrus/config": "workspace:*",
    "typescript": "catalog:"
  }
}
